# Core runtime
HOST=0.0.0.0
PORT=3080
NODE_ENV=production
TRUST_PROXY=1
CONFIG_PATH=/app/librechat.yaml

# Public domain (Railway custom domain)
DOMAIN_SERVER=https://chat.example.com
DOMAIN_CLIENT=https://chat.example.com

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/LibreChat

# App secrets (generate unique values)
JWT_SECRET=replace_with_long_random_value
JWT_REFRESH_SECRET=replace_with_long_random_value
CREDS_KEY=replace_with_64_hex_chars
CREDS_IV=replace_with_32_hex_chars

# Authentication: Keycloak OpenID Connect
ALLOW_EMAIL_LOGIN=false
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true
OPENID_CLIENT_ID=librechat
OPENID_CLIENT_SECRET=replace_with_keycloak_client_secret
OPENID_ISSUER=https://keycloak.example.com/realms/myrealm
OPENID_SESSION_SECRET=replace_with_long_random_value
OPENID_SCOPE=openid profile email
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_AUTO_REDIRECT=true

# Optional role mapping from token claims
# OPENID_REQUIRED_ROLE=librechat_user
# OPENID_REQUIRED_ROLE_TOKEN_KIND=access_token
# OPENID_REQUIRED_ROLE_PARAMETER_PATH=realm_access.roles
# OPENID_ADMIN_ROLE=librechat_admin
# OPENID_ADMIN_ROLE_TOKEN_KIND=access_token
# OPENID_ADMIN_ROLE_PARAMETER_PATH=realm_access.roles

# LiteLLM gateway (OpenAI-compatible)
LITELLM_BASE_URL=https://litellm.example.com/v1
LITELLM_API_KEY=replace_with_litellm_key

# Keep native provider keys empty to prevent extra providers exposure
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_KEY=
ASSISTANTS_API_KEY=
